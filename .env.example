# Expo only inlines vars prefixed with EXPO_PUBLIC_ into the app bundle.
# Copy this file to `.env` and adjust for your environment.

# Authentication Mode — 'mock' for demo/local testing, 'api' for backend integration
EXPO_PUBLIC_AUTH_MODE=mock

# Backend API base URL (must include the /api/v1 prefix).
#   Physical device : http://<your-LAN-IP>:3000/api/v1
#   Android emulator: http://10.0.2.2:3000/api/v1
#   iOS simulator   : http://localhost:3000/api/v1
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1
EXPO_PUBLIC_API_TIMEOUT=10000

# Stripe publishable key (pk_test_...). Enables native card entry (PaymentSheet).
# Leave empty to use the manual card form. Requires a dev build, not Expo Go.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
